# URL de tu proyecto Supabase (Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clave pública anónima de Supabase (Settings > API > anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Clave service_role de Supabase (Settings > API > service_role). SECRETA:
# se usa SOLO en el servidor para los enlaces de invitación por entidad.
# Nunca la expongas en el cliente ni la subas al repositorio.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Token de seguridad global para ingresar al sistema (elige uno fuerte)
SECURITY_TOKEN=mi-token-super-secreto-2026
